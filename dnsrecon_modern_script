}

# Main execution
main() {
    local domain="$1"
    local quick_mode=0
    local run_vuln_scan=0
    local run_port_scan_flag=0
    local threads=20
    local resolvers=""
    
    # Parse additional arguments
    shift
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -q|--quick) quick_mode=1; shift ;;
            -v|--vuln) run_vuln_scan=1; shift ;;
            -p|--port) run_port_scan_flag=1; shift ;;
            -t|--threads) threads="$2"; shift 2 ;;
            -r|--resolvers) resolvers="$2"; shift 2 ;;
            *) shift ;;
        esac
    done
    
    log INFO "╔════════════════════════════════════════╗"
    log INFO "║  DNS Reconnaissance Tool v${VERSION}       ║"
    log INFO "║  Modern Edition - 2026 Update          ║"
    log INFO "╚════════════════════════════════════════╝"
    
    log INFO "Domain: $domain"
    log INFO "Mode: $([ $quick_mode -eq 1 ] && echo 'Quick Scan' || echo 'Full Scan')"
    log INFO "Output Directory: $OUTPUT_DIR"
    
    check_dependencies
    validate_domain "$domain"
    setup_environment
    
    # Setup resolvers if needed
    resolvers=$(setup_resolvers "$resolvers")
    
    # Run primary enumeration
    run_subfinder "$domain" || true
    
    if [[ $quick_mode -eq 0 ]]; then
        run_findomain "$domain" || true
    fi
    
    # Combine enumeration results
    local combined_list="$OUTPUT_DIR/combined_subdomains_${TIMESTAMP}.txt"
    find "$OUTPUT_DIR/raw" -name "subfinder_*.txt" -o -name "findomain_*.txt" 2>/dev/null | xargs cat 2>/dev/null | sort -u > "$combined_list"
    
    # DNS validation
    run_dnsx "$combined_list" || true
    
    if [[ $quick_mode -eq 0 ]]; then
        run_massdns "$domain" "$resolvers" || true
    fi
    
    # Combine results
    combine_results
    
    # Optional: Port scanning
    if [[ $run_port_scan_flag -eq 1 ]]; then
        local ips_file="$OUTPUT_DIR/processed/unique_ips_${TIMESTAMP}.txt"
        if [[ -f "$ips_file" ]] && [[ -s "$ips_file" ]]; then
            run_port_scan "$ips_file" || true
        fi
    fi
    
    # Optional: Vulnerability scanning
    if [[ $run_vuln_scan -eq 1 ]]; then
        local targets="$OUTPUT_DIR/processed/resolved_hosts_${TIMESTAMP}.txt"
        if [[ -f "$targets" ]]; then
            run_vulnerability_scan "$targets" || true
        fi
    fi
    
    # Generate report
    generate_report
    
    log SUCCESS "╔════════════════════════════════════════╗"
    log SUCCESS "║  Scan Complete!                       ║"
    log SUCCESS "╚════════════════════════════════════════╝"
    log SUCCESS "Results: $OUTPUT_DIR"
    log INFO "Log file: $LOG_FILE"
}

# Entry point
if [[ $# -lt 2 ]] || [[ "$1" == "-h" ]] || [[ "$1" == "--help" ]]; then
    usage
    exit 0
fi

if [[ "$1" != "-d" ]]; then
    log ERROR "Domain must be specified with -d flag"
    usage
    exit 1
fi

main "$2" "${@:3}"
