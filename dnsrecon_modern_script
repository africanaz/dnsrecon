#!/bin/bash

set -euo pipefail

# DNS Reconnaissance Script (Modern Edition)
# Author: africanaz
# Description: Comprehensive DNS enumeration using modern, maintained tools
# Updated: 2026

# Modern tool stack: subfinder, findomain, dnsx, massdns, nuclei, httpx, jq

readonly SCRIPT_NAME=$(basename "$0")
readonly VERSION="2.0.0"
readonly LOG_FILE="dns_recon_$(date +%Y%m%d_%H%M%S).log"
readonly OUTPUT_DIR="${1:-dns_recon_results_$(date +%Y%m%d_%H%M%S)}"
readonly TIMESTAMP=$(date +%Y%m%d_%H%M%S)

# Color codes for output
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly NC='\033[0m' # No Color

# Modern tools array
readonly TOOLS=("subfinder" "findomain" "dnsx" "massdns" "nuclei" "httpx" "jq")
readonly OPTIONAL_TOOLS=("nmap" "curl")

usage() {
cat << EOF
${BLUE}DNS Reconnaissance Tool v${VERSION}${NC}

${BLUE}Usage:${NC} $SCRIPT_NAME [OPTIONS] -d DOMAIN

${BLUE}OPTIONS:${NC}
  -d DOMAIN             Target domain (required)
  -o OUTPUT_DIR         Custom output directory (default: dns_recon_results_*)
  -r RESOLVERS_FILE     Custom resolvers file for massdns
  -t THREADS            Thread count for tools (default: 20)
  -p PORT_SCAN          Enable port scanning on discovered IPs (slow)
  -v VULN_SCAN          Run vulnerability scanning with nuclei
  -q QUICK_MODE         Quick scan (subfinder + dnsx only)
  -h                    Show this help message

${BLUE}EXAMPLES:${NC}
  $SCRIPT_NAME -d example.com
  $SCRIPT_NAME -d example.com -o results_2026 -v
  $SCRIPT_NAME -d example.com -q -t 50

EOF
}

# Enhanced logging with colors
log() {
    local level="$1"
    shift
    local message="$*"
    local color=""
    
    case "$level" in
        INFO)  color="$BLUE" ;;
        SUCCESS) color="$GREEN" ;;
        WARN) color="$YELLOW" ;;
        ERROR) color="$RED" ;;
        *) color="$NC" ;;
    esac
    
    echo -e "${color}[$(date '+%Y-%m-%d %H:%M:%S')] [$level]${NC} $message" | tee -a "$LOG_FILE"
}

# Spinner animation
spin() {
    local pid=$!
    local delay=0.1
    local frames=( '⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏' )
    
    while kill -0 $pid 2>/dev/null; do
        for frame in "${frames[@]}"; do
            echo -ne "\r$frame Processing... "
            sleep $delay
        done
    done
    echo -ne "\r✓ Done\n"
}

# Check if tool is installed
check_tool() {
    if command -v "$1" &> /dev/null; then
        return 0
    else
        return 1
    fi
}

# Check dependencies
check_dependencies() {
    log INFO "Checking dependencies..."
    
    local missing_tools=()
    local missing_optional=()
    
    for tool in "${TOOLS[@]}"; do
        if ! check_tool "$tool"; then
            missing_tools+=("$tool")
        fi
    done
    
    for tool in "${OPTIONAL_TOOLS[@]}"; do
        if ! check_tool "$tool"; then
            missing_optional+=("$tool")
        fi
    done
    
    if [[ ${#missing_tools[@]} -gt 0 ]]; then
        log ERROR "Missing required tools: ${missing_tools[*]}"
        log ERROR "Install them using: go install + pip or your package manager"
        log INFO "For macOS: brew install subfinder findomain dnsx massdns"
        log INFO "For Linux: apt-get install massdns, then use go install for Go tools"
        exit 1
    fi
    
    if [[ ${#missing_optional[@]} -gt 0 ]]; then
        log WARN "Optional tools missing: ${missing_optional[*]} (some features may be limited)"
    fi
    
    log SUCCESS "All required tools are available"
}

# Validate domain format
validate_domain() {
    local domain="$1"
    
    if [[ ! "$domain" =~ ^([a-zA-Z0-9]([a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?\.)+[a-zA-Z0-9]([a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?$ ]]; then
        log ERROR "Invalid domain format: $domain"
        exit 1
    fi
    
    log SUCCESS "Domain validated: $domain"
}

# Setup output environment
setup_environment() {
    if [[ -d "$OUTPUT_DIR" ]]; then
        log WARN "Output directory exists: $OUTPUT_DIR (results will be appended)"
    else
        mkdir -p "$OUTPUT_DIR"
        log SUCCESS "Created output directory: $OUTPUT_DIR"
    fi
    
    # Create subdirectories for organized output
    mkdir -p "$OUTPUT_DIR/raw" "$OUTPUT_DIR/processed" "$OUTPUT_DIR/logs"
}

# Download public resolvers if not provided
setup_resolvers() {
    local resolvers_file="${1:-$OUTPUT_DIR/resolvers.txt}"
    
    if [[ ! -f "$resolvers_file" ]]; then
        log INFO "Downloading public resolvers..."
        if curl -s "https://raw.githubusercontent.com/trickest/resolvers/main/resolvers.txt" -o "$resolvers_file" 2>/dev/null; then
            log SUCCESS "Downloaded $(wc -l < "$resolvers_file") resolvers"
        else
            log WARN "Could not download resolvers, using system resolvers"
            cat /etc/resolv.conf | grep nameserver | awk '{print $2}' > "$resolvers_file"
        fi
    fi
    
    echo "$resolvers_file"
}

# Run subfinder (fast, reliable subdomain enumeration)
run_subfinder() {
    local domain="$1"
    local output="$OUTPUT_DIR/raw/subfinder_${TIMESTAMP}.txt"
    
    log INFO "Running subfinder (multiple sources)..."
    
    if subfinder -d "$domain" -all -o "$output" -silent 2>/dev/null; then
        local count=$(wc -l < "$output")
        log SUCCESS "Subfinder found $count subdomains"
        return 0
    else
        log WARN "Subfinder encountered an issue"
        return 1
    fi
}

# Run findomain (fast alternative/complement)
run_findomain() {
    local domain="$1"
    local output="$OUTPUT_DIR/raw/findomain_${TIMESTAMP}.txt"
    
    log INFO "Running findomain..."
    
    if findomain -t "$domain" > "$output" 2>/dev/null; then
        local count=$(wc -l < "$output")
        log SUCCESS "Findomain found $count subdomains"
        return 0
    else
        log WARN "Findomain encountered an issue"
        return 1
    fi
}

# DNS validation and resolution with dnsx
run_dnsx() {
    local input_file="$1"
    local output="$OUTPUT_DIR/raw/dnsx_resolved_${TIMESTAMP}.txt"
    
    log INFO "Validating DNS records and resolving IPs (dnsx)..."
    
    if [[ ! -f "$input_file" ]]; then
        log ERROR "Input file not found: $input_file"
        return 1
    fi
    
    if dnsx -list "$input_file" -a -aaaa -cname -ns -soa -json -o "$output" 2>/dev/null; then
        log SUCCESS "DNS validation completed"
        # Convert JSON to readable format
        jq -r '.host' "$output" 2>/dev/null | sort -u > "$OUTPUT_DIR/processed/resolved_hosts_${TIMESTAMP}.txt"
        return 0
    else
        log WARN "dnsx validation partially failed"
        return 1
    fi
}

# Mass DNS resolution with massdns
run_massdns() {
    local domain="$1"
    local resolvers="$2"
    local output="$OUTPUT_DIR/raw/massdns_${TIMESTAMP}.txt"
    
    log INFO "Running massdns for batch resolution..."
    
    if [[ ! -f "$resolvers" ]]; then
        log WARN "Resolvers file not found, skipping massdns"
        return 1
    fi
    
    # Generate subdomain list from domain
    local subdomains_file="$OUTPUT_DIR/subdomains_${TIMESTAMP}.txt"
    cat "$OUTPUT_DIR"/raw/subfinder_*.txt "$OUTPUT_DIR"/raw/findomain_*.txt 2>/dev/null | sort -u > "$subdomains_file"
    
    if massdns -r "$resolvers" -t A -o S "$subdomains_file" 2>/dev/null | tee "$output" > /dev/null; then
        log SUCCESS "Massdns resolution completed"
        return 0
    else
        log WARN "Massdns encountered issues"
        return 1
    fi
}

# Combine and deduplicate results
combine_results() {
    log INFO "Combining and deduplicating results..."
    
    local combined_file="$OUTPUT_DIR/processed/all_subdomains_${TIMESTAMP}.txt"
    local ips_file="$OUTPUT_DIR/processed/unique_ips_${TIMESTAMP}.txt"
    
    # Combine subdomains
    find "$OUTPUT_DIR/raw" -name "subfinder_*.txt" -o -name "findomain_*.txt" | xargs cat 2>/dev/null | sort -u > "$combined_file"
    
    # Extract unique IPs from dnsx/massdns results
    find "$OUTPUT_DIR/raw" -name "dnsx_*.txt" -o -name "massdns_*.txt" | xargs grep -oE '([0-9]{1,3}\.){3}[0-9]{1,3}' 2>/dev/null | sort -u > "$ips_file"
    
    log SUCCESS "Combined $(wc -l < "$combined_file") unique subdomains"
    [[ -f "$ips_file" ]] && log SUCCESS "Found $(wc -l < "$ips_file") unique IP addresses"
}

# Port scanning on discovered IPs
run_port_scan() {
    local ips_file="$1"
    local output="$OUTPUT_DIR/processed/nmap_ports_${TIMESTAMP}.txt"
    
    if ! check_tool "nmap"; then
        log WARN "nmap not installed, skipping port scanning"
        return 1
    fi
    
    log INFO "Running nmap on discovered IPs (this may take a while)..."
    
    if nmap -iL "$ips_file" -p 80,443,8080,8443,3306,5432 -T4 -oG "$output" 2>/dev/null; then
        log SUCCESS "Port scan completed"
        return 0
    else
        log WARN "Port scan encountered issues"
        return 1
    fi
}

# Vulnerability scanning with nuclei
run_vulnerability_scan() {
    local targets_file="$1"
    local output="$OUTPUT_DIR/processed/nuclei_results_${TIMESTAMP}.json"
    
    log INFO "Running nuclei for vulnerability detection..."
    
    if [[ ! -f "$targets_file" ]]; then
        log WARN "Targets file not found, creating from resolved hosts"
        cat "$OUTPUT_DIR"/processed/resolved_hosts_*.txt 2>/dev/null | grep -E "^http" > "$targets_file" || \
        awk '{print "http://" $0}' "$OUTPUT_DIR"/processed/unique_ips_*.txt > "$targets_file"
    fi
    
    if nuclei -list "$targets_file" -json -o "$output" -severity medium,high,critical 2>/dev/null; then
        log SUCCESS "Vulnerability scan completed"
        return 0
    else
        log WARN "Nuclei scan had issues"
        return 1
    fi
}

